{
  "name": "@flipmorsch/react-spatial-navigation",
  "version": "1.0.0",
  "description": "Spatial navigation library for React",
  "author": "Felipe Marques",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/flipmorsch/react-spatial-navigation.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tsup": "^8.0.2",
    "typescript": "^5.0.0"
  }
}
